{
  "uid": "vidlens-task-overview",
  "title": "VidLens / 任务处理总览",
  "tags": [
    "vidlens",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "阶段处理速率",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stage, status) (rate(vidlens_task_stage_total[5m]))",
          "legendFormat": "{{stage}} / {{status}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "阶段 P95 耗时",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(vidlens_task_stage_duration_seconds_bucket[5m])))",
          "legendFormat": "{{stage}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "重试原因",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job_type, error_code) (increase(vidlens_task_retry_total[1h]))",
          "legendFormat": "{{job_type}} / {{error_code}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Dead 任务",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job_type) (increase(vidlens_task_dead_total[1h]))",
          "legendFormat": "{{job_type}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Kafka Job P95",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, job_type) (rate(vidlens_kafka_job_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job_type}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    }
  ]
}
